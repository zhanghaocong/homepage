    "preview": "npm run build && vite preview",
    "typecheck": "npm run cf-typegen && tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
