{
  "name": "homepage-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter homepage dev",
    "build": "pnpm --filter homepage build",
    "deploy": "pnpm --filter homepage deploy",
    "check": "pnpm --filter homepage check",
    "typecheck": "pnpm --filter homepage typecheck",
    "lint": "pnpm --filter homepage lint",
    "lint:fix": "pnpm --filter homepage lint:fix",
    "format": "pnpm --filter homepage format",
    "format:check": "pnpm --filter homepage format:check",
    "r2:sync": "pnpm --filter @internal/albums sync",
    "r2:prune": "pnpm --filter @internal/albums prune",
    "r2:prune:dry-run": "pnpm --filter @internal/albums prune:dry-run",
    "r2:setup": "pnpm --filter @internal/albums setup",
    "r2:create": "pnpm --filter @internal/albums create-bucket",
    "builds:previews": "bash packages/homepage/scripts/list-preview-builds.sh"
  }
}
